{
  "name": "@riftborn/mcp-server",
  "version": "2.1.0",
  "type": "module",
  "description": "MCP Server for RiftbornAI plugin - bridges VS Code Copilot to Unreal Engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "riftborn-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint .",
    "test": "node scripts/run-vitest.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "BSL-1.1",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unreal-engine",
    "riftborn",
    "ai",
    "copilot"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.38.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
