  "VersionName": "0.1.0-beta.7",
  "FriendlyName": "RiftbornAI Copilot",
  "Description": "Transaction-safe AI copilot for Unreal Engine. Production packaging focuses on governed editor inspection and controlled scene automation, with broader beta and internal tool surfaces behind readiness gates. Governance kernel: all mutations require confirmation tokens, destructive operations are fail-closed, and each action produces HMAC-SHA256 signed proof bundles. Intent parsing runs locally via Ollama; no cloud services or telemetry unless explicitly configured.",
  "Category": "Editor",
  "CreatedBy": "Riftborn Studios",
  "CreatedByURL": "https://riftborn.io",
  "DocsURL": "https://github.com/RiftbornGit/RiftbornAI/tree/main/docs",
  "MarketplaceURL": "",
  "SupportURL": "https://github.com/RiftbornGit/RiftbornAI/issues",
  "CanContainContent": true,
  "IsBetaVersion": true,
  "IsExperimentalVersion": false,
  "Installed": false,
  "EnabledByDefault": true,
